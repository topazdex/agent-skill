# dependencies
node_modules/
.pnp.*

# yarn 4 caches (regenerated by `yarn install`; keep .yarn/releases + plugins committed)
**/.yarn/cache/
**/.yarn/unplugged/
**/.yarn/build-state.yml
**/.yarn/install-state.gz

# env / secrets
.env
.env.*
!.env.example

# build output
dist/
build/
coverage/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# editor / OS
.DS_Store
.idea/
.vscode/

# local Claude Code config + private dev notes (machine-specific, not for distribution)
.claude/
