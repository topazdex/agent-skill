{
  "name": "topaz-skill-scripts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript helpers and builder references for interacting with Topaz Dex on BNB Mainnet (chain id 56).",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./addresses": "./src/config/addresses.ts",
    "./tokens": "./src/config/tokens.ts",
    "./quotes": "./src/read/quotes.ts",
    "./action-builders": "./src/lib/actionBuilders.ts",
    "./tx-builders": "./src/lib/txBuilders.ts",
    "./relay-builders": "./src/lib/relayBuilders.ts",
    "./relays": "./src/config/relays.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "tsx": "tsx",
    "build": "tsc --noEmit",
    "validate": "tsx src/cli/validate.ts",
    "smoke": "tsx src/cli/stats.ts smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "evals": "tsx src/cli/evals.ts",
    "release": "tsx src/cli/release.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.14.10",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
