# Topaz skill — local environment
#
# Copy to `.env` and fill in. Only BSC_RPC_URL is required for read-only ops.
# PRIVATE_KEY is required for any write operation (swap, lp, lock, vote, claim, bribe).
# Subgraph URLs default to the Goldsky-hosted endpoints; override if you have a private indexer.

# Required: BSC mainnet JSON-RPC. Default public endpoints below — replace with your own
# for production use to avoid rate limits.
BSC_RPC_URL=https://bsc-rpc.publicnode.com

# Optional: backup RPC tried if BSC_RPC_URL fails.
# BSC_RPC_URL_FALLBACK=https://1rpc.io/bnb

# Required for write operations. Hex string starting with 0x.
# DO NOT COMMIT THE REAL VALUE.
PRIVATE_KEY=

# Optional overrides (defaults baked into scripts/src/lib/subgraph.ts).
SUBGRAPH_V2_URL=https://api.goldsky.com/api/public/project_cmgzljqwl006c5np2gnao4li4/subgraphs/topaz-v2/prod/gn
SUBGRAPH_V3_URL=https://api.goldsky.com/api/public/project_cmgzljqwl006c5np2gnao4li4/subgraphs/topaz-v3/prod/gn

# Optional: DexScreener pair address for canonical TOPAZ price lookup.
# By default, scripts derive TOPAZ USD via v3 subgraph (Token.derivedETH * Bundle.ethPriceUSD).
# Set this to skip subgraph and query DexScreener directly.
# DEXSCREENER_TOPAZ_PAIR=
